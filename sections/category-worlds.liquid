<section class="py-[40px] px-[40px] bg-bg">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-[24px] h-auto lg:h-[450px]">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="relative group overflow-hidden cursor-pointer h-[400px] lg:h-full bg-surface border border-border">
        {% if block.settings.image != blank %}
          <img alt="{{ block.settings.title }}" class="absolute inset-0 w-full h-full object-cover z-0 transition-transform duration-700 group-hover:scale-105" src="{{ block.settings.image | img_url: '600x' }}">
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover z-0 bg-gray-200' }}
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-80 z-10 pointer-events-none"></div>
        <div class="absolute bottom-[20px] left-[20px] z-20">
          <h3 class="text-textMain text-[14px] font-semibold mb-1 headline">{{ block.settings.title }}</h3>
          <span class="text-textSecondary text-[13px]">{{ block.settings.subtitle }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Category Worlds",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Worlds",
      "category": "Collection",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
