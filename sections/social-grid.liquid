<section class="max-w-7xl mx-auto px-[40px] py-[60px] bg-bg">
  <div class="flex flex-col items-center text-center mb-[40px]">
    <h2 class="text-[48px] font-semibold text-textMain mb-[24px] headline">{{ section.settings.heading }}</h2>
    <p class="text-textSecondary max-w-[400px] text-[16px] leading-[1.6]">{{ section.settings.subheading }}</p>
  </div>
  
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
    {% for block in section.blocks %}
      <div class="flex flex-col group cursor-pointer h-full">
        <div class="relative w-full aspect-[9/16] overflow-hidden mb-3 bg-[#f0f0f0]">
          {% if block.settings.image != blank %}
             <img src="{{ block.settings.image | img_url: '400x' }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Social Post">
          {% else %}
             {{ 'image' | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover bg-gray-200' }}
          {% endif %}
          <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/80 to-transparent">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-white/20 overflow-hidden">
                 {% if block.settings.avatar != blank %}
                   <img src="{{ block.settings.avatar | img_url: '50x' }}" class="w-full h-full object-cover" alt="User Avatar">
                 {% endif %}
              </div>
              <span class="text-white text-[11px] font-medium">{{ block.settings.handle }}</span>
            </div>
          </div>
        </div>
        <p class="text-[13px] text-textMain font-medium leading-snug mb-3 flex-1 line-clamp-2">{{ block.settings.text }}</p>
        
        {% if block.settings.product != blank %}
          <a href="{{ block.settings.product.url }}" class="flex items-center gap-3 p-2 bg-surface hover:bg-[#EAEAEA] transition-colors mt-auto border border-border">
             <div class="w-10 h-10 bg-white flex-shrink-0">
               <img src="{{ block.settings.product.featured_image | img_url: '100x' }}" class="w-full h-full object-contain mix-blend-multiply" alt="{{ block.settings.product.title }}">
             </div>
             <div class="flex flex-col flex-1 overflow-hidden">
               <span class="text-[10px] text-textSecondary uppercase tracking-wider">{{ block.settings.product.vendor }}</span>
               <span class="text-[11px] font-semibold text-textMain truncate">{{ block.settings.product.title }}</span>
             </div>
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Social Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending on Social"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover how real customers use our products every day."
    }
  ],
  "blocks": [
    {
      "type": "social_post",
      "name": "Social Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post Image (Vertical)"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "User Avatar"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Social Handle",
          "default": "@username"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Caption text",
          "default": "Loving my new product! ✨"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Link to Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Grid",
      "category": "Social",
      "blocks": [
        { "type": "social_post" },
        { "type": "social_post" },
        { "type": "social_post" }
      ]
    }
  ]
}
{% endschema %}
