{% section 'hero' %}

<section class="py-[80px] px-[40px] bg-surface border-y border-border">
  <div class="flex justify-between items-end mb-[48px]">
    <div>
      <h2 class="text-[32px] font-semibold tracking-tight headline text-textMain">Featured Products</h2>
    </div>
    <a class="text-[14px] font-medium border-b border-textMain pb-[2px] text-textMain hover:opacity-80 transition-opacity" href="{{ routes.all_products_collection_url }}">View All Products</a>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[24px]">
    {% for product in collections.frontpage.products limit: 4 %}
      <a href="{{ product.url }}" class="group cursor-pointer bg-bg border border-border p-[20px] transition-colors hover:border-textSecondary">
        <div class="relative aspect-square bg-[#f0f0f0] overflow-hidden mb-[24px] flex items-center justify-center p-[20px]">
          <span class="absolute top-[10px] left-[10px] bg-bg text-textMain text-[11px] font-semibold uppercase tracking-[1px] px-[12px] py-[6px] border border-border z-10">Best Seller</span>
          <img class="max-h-full max-w-full object-contain mix-blend-multiply group-hover:scale-105 transition-transform duration-500 opacity-90" src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
          <button class="absolute bottom-[20px] left-[20px] right-[20px] bg-accent text-white py-[14px] font-medium uppercase text-[12px] tracking-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-300">Add to cart</button>
        </div>
        <div class="flex flex-col">
          <div class="flex justify-between items-center mb-1">
            <h4 class="font-semibold text-[15px] text-textMain">{{ product.title }}</h4>
            <span class="font-medium text-[15px] text-textMain">{{ product.price | money }}</span>
          </div>
          <p class="text-textSecondary text-[12px] font-medium tracking-[1px] uppercase mt-2">{{ product.type }}</p>
        </div>
      </a>
    {% else %}
      <p>No products found in the "frontpage" collection.</p>
    {% endfor %}
  </div>
</section>
